# Oryxis Sync — Signaling Server configuration
# Copy this file to .env and fill with your values

# URL of your Cloudflare Worker signaling server
ORYXIS_SIGNALING_URL=https://oryxis-signaling.YOUR_SUBDOMAIN.workers.dev

# Bearer token configured on the Worker (wrangler secret put SIGNALING_TOKEN)
ORYXIS_SIGNALING_TOKEN=oryxis-sync-v1-public

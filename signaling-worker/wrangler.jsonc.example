{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "signaling",
  "main": "worker.js",
  "compatibility_date": "2025-02-04",
  "observability": {
    "enabled": true
  },

  // To deploy:
  // 1. cp wrangler.jsonc.example wrangler.jsonc
  // 2. wrangler login
  // 3. Create a KV namespace in the CF dashboard or: wrangler kv namespace create SYNC_KV
  // 4. Paste the ID below
  // 5. wrangler deploy (also runs the v1 DO migration on the first deploy)
  // 6. wrangler secret put SIGNALING_TOKEN (enter same value as ORYXIS_SIGNALING_TOKEN in .env)

  "kv_namespaces": [
    {
      // Used by the relay queue (`relay:*` keys). The discovery
      // routes (`/register`, `/lookup`) live in the DeviceRegistry
      // Durable Object below to get atomic single-writer TOFU per
      // device_id.
      "binding": "SYNC_KV",
      "id": ""
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        // Per-device discovery state. One DO instance per device_id
        // (via `idFromName(device_id)`); each instance is
        // single-writer, so the TOFU check-then-pin sequence runs
        // serialized and the race that a KV-only path would have is
        // eliminated.
        "name": "DEVICE_REGISTRY",
        "class_name": "DeviceRegistry"
      }
    ]
  },

  "migrations": [
    {
      // First migration: introduce the DeviceRegistry class. Bumping
      // the schema later (rename, delete) requires a new tag entry,
      // never edit `v1` in place.
      "tag": "v1",
      "new_classes": ["DeviceRegistry"]
    }
  ]
}
